{
  "target_family": "xmate6",
  "alignment_scope": "call_build_only",
  "contract_source": "single_source_manifest",
  "baseline": {
    "headers": [
      "librokae/include/rokae/base.h",
      "librokae/include/rokae/data_types.h",
      "librokae/include/rokae/exception.h",
      "librokae/include/rokae/model.h",
      "librokae/include/rokae/motion_control_rt.h",
      "librokae/include/rokae/planner.h",
      "librokae/include/rokae/robot.h",
      "librokae/include/rokae/utility.h"
    ],
    "examples": [
      "librokae/example/sdk_example.cpp",
      "librokae/example/move_example.cpp",
      "librokae/example/read_robot_state.cpp",
      "librokae/example/path_record.cpp"
    ]
  },
  "unsupported_public_modules": [
    "io",
    "rl",
    "calibration"
  ],
  "unsupported_contract": {
    "source_compatible_symbols": true,
    "runtime_policy": "deterministic_not_implemented",
    "error_code_symbol": "SdkError::not_implemented"
  },
  "profiles": {
    "nrt": "nrt_strict_parity",
    "rt": "rt_sim_experimental_best_effort",
    "rt_policy": "best_effort_non_controller_grade"
  },
  "checks": {
    "header_patterns": [
      {
        "file": "include/rokae/robot.h",
        "contains": "Toolset setToolset(const std::string &toolName, const std::string &wobjName, error_code &ec) noexcept;"
      },
      {
        "file": "include/rokae/robot.h",
        "contains": "std::array<double, 6> flangePos(error_code &ec) const noexcept;"
      },
      {
        "file": "include/rokae/robot.h",
        "contains": "[[deprecated(\"Use jointTorque() instead\")]]"
      }
    ],
    "compat_patterns": [
      {
        "file": "src/compat/robot_api.cpp",
        "contains": "throw_if_error<ExecutionException>(ec, \"connectToRobot\");"
      },
      {
        "file": "src/compat/robot_api.cpp",
        "contains": "Robot_T<WorkType::collaborative, 6>::Robot_T(const std::string &remoteIP, const std::string &localIP)"
      },
      {
        "file": "src/compat/robot_api.cpp",
        "contains": "throw_if_error<ExecutionException>(ec, \"Robot_T::Robot_T(connectToRobot)\");"
      },
      {
        "file": "src/compat/robot_api.cpp",
        "contains": "if (remoteIP.empty()) {"
      },
      {
        "file": "src/compat/robot_api.cpp",
        "contains": "if (!has_remote_endpoint(handle_)) {"
      },
      {
        "file": "src/compat/internal/compat_shared.hpp",
        "contains": "std::string remote_ip;"
      }
    ],
    "runtime_patterns": [
      {
        "file": "src/runtime/runtime_profile_service.cpp",
        "contains": "nrt_strict_parity"
      },
      {
        "file": "src/runtime/runtime_profile_service.cpp",
        "contains": "rt_sim_experimental_best_effort"
      },
      {
        "file": "src/runtime/runtime_profile_service.cpp",
        "contains": "best-effort simulation-grade RT"
      }
    ],
    "docs_patterns": [
      {
        "file": "docs/XMATE6_OFFICIAL_ALIGNMENT_MATRIX.md",
        "contains": "single-source manifest"
      },
      {
        "file": "docs/XMATE6_OFFICIAL_ALIGNMENT_MATRIX.md",
        "contains": "rt_sim_experimental_best_effort"
      },
      {
        "file": "docs/COMPAT_ABI.md",
        "contains": "single-source manifest"
      },
      {
        "file": "docs/COMPAT_ABI.md",
        "contains": "best-effort non-controller-grade RT profile"
      }
    ],
    "cmake_patterns": [
      {
        "file": "CMakeLists.txt",
        "contains": "set(ROKAE_PUBLIC_UNSUPPORTED_MODULES \"io;rl;calibration\""
      }
    ]
  }
}
