@PACKAGE_INIT@
include(CMakeFindDependencyMacro)

# The compatibility package is still ROS2/Gazebo-backed. Both public targets are real install-facing
# libraries, and the install contract is frozen to the xMate6 compatibility lane. The static target
# still packages the compatibility facade together with the internal runtime/backend object code.
# Downstream consumers therefore need the same ROS2/Gazebo dependency set that the shipped
# compatibility implementation links against.
find_dependency(Eigen3 REQUIRED NO_MODULE)
find_dependency(ament_index_cpp REQUIRED CONFIG)
find_dependency(rclcpp REQUIRED CONFIG)
find_dependency(rclcpp_action REQUIRED CONFIG)
find_dependency(std_msgs REQUIRED CONFIG)
find_dependency(sensor_msgs REQUIRED CONFIG)
find_dependency(geometry_msgs REQUIRED CONFIG)
find_dependency(control_msgs REQUIRED CONFIG)
find_dependency(trajectory_msgs REQUIRED CONFIG)
find_dependency(rosidl_runtime_cpp REQUIRED CONFIG)
find_dependency(unique_identifier_msgs REQUIRED CONFIG)
find_dependency(action_msgs REQUIRED CONFIG)
find_dependency(gazebo_ros REQUIRED CONFIG)
find_dependency(kdl_parser REQUIRED CONFIG)

# The install-facing compatibility targets currently link against this package's generated
# ROSIDL typesupport target. In staged-install consumer tests the parent package config is not
# always discoverable, so load the generated export files directly when available.
if(NOT TARGET rokae_xmate3_ros2::rokae_xmate3_ros2__rosidl_typesupport_cpp)
  get_filename_component(_xcoresdk_pkg_prefix "${CMAKE_CURRENT_LIST_DIR}" DIRECTORY)
  get_filename_component(_xcoresdk_pkg_prefix "${_xcoresdk_pkg_prefix}" DIRECTORY)
  get_filename_component(_xcoresdk_pkg_prefix "${_xcoresdk_pkg_prefix}" DIRECTORY)
  set(_xcoresdk_rosidl_export_dir "${_xcoresdk_pkg_prefix}/share/rokae_xmate3_ros2/cmake")
  if(EXISTS "${_xcoresdk_rosidl_export_dir}/export_rokae_xmate3_ros2__rosidl_generator_cppExport.cmake")
    include("${_xcoresdk_rosidl_export_dir}/export_rokae_xmate3_ros2__rosidl_generator_cppExport.cmake")
  endif()
  if(EXISTS "${_xcoresdk_rosidl_export_dir}/rokae_xmate3_ros2__rosidl_typesupport_cppExport.cmake")
    include("${_xcoresdk_rosidl_export_dir}/rokae_xmate3_ros2__rosidl_typesupport_cppExport.cmake")
  endif()
  unset(_xcoresdk_rosidl_export_dir)
  unset(_xcoresdk_pkg_prefix)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/xCoreSDKTargets.cmake")

set(xCoreSDK_TARGET_FAMILY "xmate6")
set(xCoreSDK_PUBLIC_SCOPE "compat")
set(xCoreSDK_BACKEND_MODE "ros_gazebo_backed")
set(xCoreSDK_UNSUPPORTED_MODULES "@ROKAE_PUBLIC_UNSUPPORTED_MODULES@")
set(xCoreSDK_XMATE6_ONLY TRUE)

set(xCoreSDK_STRICT_PUBLIC_INSTALL TRUE)
if(TARGET xCoreSDK::xCoreSDK_static)
  set(xCoreSDK_HAS_NATIVE_STATIC_TARGET TRUE)
  set(xCoreSDK_STATIC_PROVIDER "native-static")
else()
  set(xCoreSDK_HAS_NATIVE_STATIC_TARGET FALSE)
  set(xCoreSDK_STATIC_PROVIDER "unavailable")
endif()

if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/xCoreSDKPrivateTargets.cmake")
  include("${CMAKE_CURRENT_LIST_DIR}/xCoreSDKPrivateTargets.cmake")
endif()

check_required_components(xCoreSDK)
