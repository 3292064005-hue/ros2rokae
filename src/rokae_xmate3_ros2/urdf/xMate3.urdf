        <mesh filename="package://rokae_xmate3_ros2/meshes/collision/xMate3_link6.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    </collision>
  </link>
  <gazebo>
    <plugin name="gazebo_joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <frame_name>world</frame_name>
      <joint_name>xmate_joint_1</joint_name>
      <joint_name>xmate_joint_2</joint_name>
      <joint_name>xmate_joint_3</joint_name>
      <joint_name>xmate_joint_4</joint_name>
      <joint_name>xmate_joint_5</joint_name>
      <joint_name>xmate_joint_6</joint_name>
      <update_rate>50</update_rate>
    </plugin>
  </gazebo>
</robot>