    <inertial>
    <mass value="1.229800857"/>
    <inertia ixx="0.002" ixy="0" ixz="0" 
            iyy="0.002" iyz="0" 
            izz="0.002"/>
    <origin rpy="0 0 0" xyz="0 0.017 -0.043"/>
    </inertial>
    <collision>
