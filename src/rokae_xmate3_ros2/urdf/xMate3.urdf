    <actuator name="motor4">
      <hardwareInterface>EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <!--link 4-->
  <link name="xMate3_link4">
    <visual>
      <geometry>
        <mesh filename="package://rokae_xmate3_ros2/meshes/visual/xMate3_link4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <material name="white"/>
    </visual>
    <inertial>
    <mass value="2.439584706"/>
    <inertia ixx="0.022" ixy="0" ixz="0" 
            iyy="0.022" iyz="0" 
            izz="0.004"/>
    <origin rpy="0 0 0" xyz="0 -0.020 -0.046"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="package://rokae_xmate3_ros2/meshes/collision/xMate3_link4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    </collision>
  </link>
  <joint name="xmate_joint_5" type="revolute">
    <parent link="xMate3_link4"/>
    <child link="xMate3_link5"/>
    <limit effort="300" lower="-2.0933" upper="2.0933" velocity="10"/>
    <axis xyz="0 1 0"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <!-- ✅ 添加阻尼 -->
    <dynamics damping="1.0"/>
  </joint>
  <transmission name="tran5">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="xmate_joint_5">
      <hardwareInterface>EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor5">
      <hardwareInterface>EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <!--link 5-->
  <link name="xMate3_link5">
    <visual>
      <geometry>
        <mesh filename="package://rokae_xmate3_ros2/meshes/visual/xMate3_link5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
    <mass value="2.422757896"/>
    <inertia ixx="0.016" ixy="0" ixz="0" 
            iyy="0.015" iyz="0" 
            izz="0.031"/>
    <origin rpy="0 0 0" xyz="0 0.012 0.096"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="package://rokae_xmate3_ros2/meshes/collision/xMate3_link5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>
  <joint name="xmate_joint_6" type="revolute">
    <parent link="xMate3_link5"/>
    <child link="xMate3_link6"/>
    <limit effort="300" lower="-6.1082" upper="6.1082" velocity="10"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0.0 0.0 0" xyz="0 0 0.2503"/>
    <!-- ✅ 添加阻尼 -->
    <dynamics damping="1.0"/>
  </joint>
  <transmission name="tran6">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="xmate_joint_6">
