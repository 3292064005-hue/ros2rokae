# SetRtControlMode.srv - 设置机器人实时控制模式
# mode values follow rokae::RtControllerMode semantics
int32 mode  # 0: jointPosition, 1: cartesianPosition, 2: jointImpedance, 3: cartesianImpedance, 4: torque
float32 TIMEOUT = 0.0
bool ENABLE_SAFETY_CHECK = true
---
bool success
int32 error_code
string error_msg
